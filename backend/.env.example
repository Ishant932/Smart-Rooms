MONGODB_URI=mongodb+srv://smartroomsApp:PASSWORD@smartrooms.oayo0ex.mongodb.net/smartrooms?retryWrites=true&w=majority
MONGODB_DB=smartrooms
JWT_SECRET=change-me-in-production
PORT=5000
ATLAS_PROJECT=Smart Rooms
ATLAS_CLUSTER=SmartRooms

# Resend (needs verified domain to email any user)
RESEND_API_KEY=re_xxxxxxxx
RESEND_FROM=SmartRoooms <noreply@your-verified-domain.com>

# Optional Gmail SMTP (can email any user without Resend domain)
# Create App Password: Google Account → Security → App passwords
GMAIL_USER=you@gmail.com
GMAIL_APP_PASSWORD=xxxx xxxx xxxx xxxx
SMTP_HOST=smtp.gmail.com
SMTP_PORT=587
SMTP_FROM=SmartRoooms <you@gmail.com>

# Never show OTP in the browser for real email flow
OTP_INLINE_FALLBACK=false

# GitHub Actions mail relay (Railway free blocks SMTP; Actions runners can send Gmail)
# Create a classic PAT with `repo` scope, or use `gh auth token` for local/dev.
GITHUB_MAIL_TOKEN=
GITHUB_REPO=Ishant932/Smart-Rooms
MAIL_RELAY_SECRET=
